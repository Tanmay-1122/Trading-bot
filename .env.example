# Binance Futures Testnet API Credentials
# ================================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# Get your testnet API keys from:
# https://testnet.binancefuture.com -> Account -> API Key

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Optional: Server Configuration
# PORT=5000
# LOG_LEVEL=INFO

# Optional: Binance Configuration
# Use testnet by default. Uncomment to switch to mainnet (not recommended for testing)
# BINANCE_BASE_URL=https://fapi.binance.com

# Example with real values (DO NOT COMMIT):
# BINANCE_API_KEY=d123456789abcdef
# BINANCE_API_SECRET=a987654321fedcba
